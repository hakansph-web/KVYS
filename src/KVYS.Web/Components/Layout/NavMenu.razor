@inject NavigationManager Navigation

<div class="nav-section">
    <div class="nav-section-title">Ana Sayfa</div>
    <NavLink class="nav-item" href="/" Match="NavLinkMatch.All">
        <svg class="nav-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            <polyline points="9,22 9,12 15,12 15,22"/>
        </svg>
        <span>Dashboard</span>
    </NavLink>
</div>

<div class="nav-section">
    <div class="nav-section-title">Egitim</div>

    <div class="nav-group @(educationExpanded ? "expanded" : "")">
        <button class="nav-group-toggle" @onclick="() => educationExpanded = !educationExpanded">
            <span class="flex items-center gap-sm">
                <svg class="nav-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                    <path d="M6 12v5c3 3 9 3 12 0v-5"/>
                </svg>
                <span>Egitim Yonetimi</span>
            </span>
            <svg class="nav-group-toggle-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M6 9l6 6 6-6"/>
            </svg>
        </button>
        <div class="nav-group-items">
            <NavLink class="nav-item" href="/faculties">
                <span>Fakulteler</span>
            </NavLink>
            <NavLink class="nav-item" href="/programs">
                <span>Programlar</span>
            </NavLink>
            <NavLink class="nav-item" href="/courses">
                <span>Dersler</span>
            </NavLink>
        </div>
    </div>
</div>

<div class="nav-section">
    <div class="nav-section-title">Kalite</div>

    <div class="nav-group @(indicatorsExpanded ? "expanded" : "")">
        <button class="nav-group-toggle" @onclick="() => indicatorsExpanded = !indicatorsExpanded">
            <span class="flex items-center gap-sm">
                <svg class="nav-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 20V10"/>
                    <path d="M18 20V4"/>
                    <path d="M6 20v-4"/>
                </svg>
                <span>Gostergeler</span>
            </span>
            <svg class="nav-group-toggle-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M6 9l6 6 6-6"/>
            </svg>
        </button>
        <div class="nav-group-items">
            <NavLink class="nav-item" href="/indicators/categories">
                <span>Kategoriler</span>
            </NavLink>
            <NavLink class="nav-item" href="/indicators">
                <span>Gosterge Listesi</span>
            </NavLink>
            <NavLink class="nav-item" href="/indicators/entries">
                <span>Veri Girisi</span>
            </NavLink>
        </div>
    </div>
</div>

<div class="nav-section">
    <div class="nav-section-title">Raporlar</div>

    <div class="nav-group @(reportsExpanded ? "expanded" : "")">
        <button class="nav-group-toggle" @onclick="() => reportsExpanded = !reportsExpanded">
            <span class="flex items-center gap-sm">
                <svg class="nav-item-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                    <polyline points="14,2 14,8 20,8"/>
                    <line x1="16" y1="13" x2="8" y2="13"/>
                    <line x1="16" y1="17" x2="8" y2="17"/>
                    <polyline points="10,9 9,9 8,9"/>
                </svg>
                <span>Raporlar</span>
            </span>
            <svg class="nav-group-toggle-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M6 9l6 6 6-6"/>
            </svg>
        </button>
        <div class="nav-group-items">
            <NavLink class="nav-item" href="/reports/kidr">
                <span>KIDR Raporu</span>
            </NavLink>
            <NavLink class="nav-item" href="/reports/program">
                <span>Program Raporu</span>
            </NavLink>
            <NavLink class="nav-item" href="/reports/course">
                <span>Ders Raporu</span>
            </NavLink>
        </div>
    </div>
</div>

@code {
    private bool educationExpanded = true;
    private bool indicatorsExpanded = true;
    private bool reportsExpanded = false;
}
